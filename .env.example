# Neon Postgres connection string
DATABASE_URL=postgres://USER:PASSWORD@HOST/dbname?sslmode=require

# Used to HMAC-sign session + recovery cookies and rate-limit cookies.
# Must be 32+ chars. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
# Required in production. In dev, a per-process random key is used if missing
# (sessions reset on each server restart).
SESSION_SECRET=
