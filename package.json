{
	"name": "volunteer-tracker",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"db:push": "drizzle-kit push",
		"db:seed": "bun run src/lib/server/seed.ts",
		"db:migrate-drop-username": "bun run src/lib/server/migrate-drop-username.ts"
	},
	"devDependencies": {
		"@sveltejs/adapter-auto": "^7.0.1",
		"@sveltejs/kit": "^2.50.2",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"drizzle-kit": "^0.31.10",
		"svelte": "^5.54.0",
		"svelte-check": "^4.4.2",
		"typescript": "^5.9.3",
		"vite": "^7.3.1"
	},
	"dependencies": {
		"@emailjs/browser": "^4.4.1",
		"@neondatabase/serverless": "^1.1.0",
		"bcrypt-ts": "^8.0.1",
		"dotenv": "^17.4.2",
		"drizzle-orm": "^0.45.2",
		"lucide-svelte": "^1.0.1"
	}
}
